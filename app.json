{
  "expo": {
    "name": "CashLens",
    "slug": "cashlens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cashlens",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cashlens.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF82",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cashlens.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CashLens to access your camera to scan receipts.",
          "microphonePermission": "Allow CashLens to access your microphone."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CashLens to access your photos to select receipt images."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": "100%",
          "imageHeight": "100%",
          "resizeMode": "contain",
          "backgroundColor": "#4CAF82",
          "dark": {
            "backgroundColor": "#1A1A2E"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e4180a4c-ac51-48b2-971a-1c41d22ddf57"
      }
    }
  }
}
